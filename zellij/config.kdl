show_startup_tips false
session_serialization false
theme "catppuccin-mocha"
default_layout "main"
pane_frames false
simplified_ui true

keybinds {
  normal clear-defaults=true {
    bind "Ctrl z" { 
      LaunchOrFocusPlugin "zellij:session-manager" {
        floating true
        move_to_focused_node true
      }
    }
    bind "Ctrl Space" { Detach; }
  }
}
