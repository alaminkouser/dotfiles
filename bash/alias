if command -v eza &> /dev/null; then
  alias ls="eza -lah --group-directories-first --color --icons --git"
else
  alias ls="ls -lah --group-directories-first --color"
fi

if command -v zoxide &> /dev/null; then
  alias cd="zoxide_z"
fi

alias zellij="XDG_RUNTIME_DIR=/run/user/$(id -u) zellij"
alias aria2c="aria2c -x 16 --seed-time=0"
alias rm="rm -rfv"
alias glow="glow -s $HOME/.config/glow/theme.json"
alias U="sudo pacman -Syu && conda update --all --yes && deno upgrade && cloudflared update"
