#!/usr/bin/env sh

# Ensure exactly one argument
if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <arg>"
    exit 1
fi

ARG=$1
KEY="$HOME/.ssh/id_rsa"

# Sign the argument using SSH key
SIGNATURE=$(echo -n "$ARG" | ssh-keygen -Y sign -f "$KEY" -n file 2>/dev/null)

# Send the argument + signature to the server (example: sending both)
RESPONSE=$(/usr/bin/printf "%s\n%s" "$ARG" "$SIGNATURE" | \
    curl -s -X PUT "https://alaminkouser.com/status/" \
         -H "Content-Type: text/plain" \
         --data-binary @-)

# Check response
if [ "$RESPONSE" = "true" ]; then
    printf "OK\n"
    exit 0
else
    printf "NOT-OK\n"
    exit 1
fi
